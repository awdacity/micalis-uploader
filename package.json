{
  "name": "micalis-uploader",
  "version": "1.0.0",
  "description": "Large file uploader with S3 multipart upload and token-based access",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/public dist/public",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "better-sqlite3": "^11.7.0",
    "busboy": "^1.6.0",
    "express": "^4.21.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
